---
import MobileHeader from "../components/MobileHeader.astro";
import Sidebar from "../components/Sidebar.astro";
import { siteMeta } from "../data/site";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title={`About | ${siteMeta.name}`}
  description=""
  canonicalPath="/about"
>
  <MobileHeader currentPath="/about" />
  <div class="desktop-frame">
    <Sidebar activePage="about" />

    <main class="page-shell">
      <section class="about-page">
        <div class="about-page__content">
          <p class="about-page__eyebrow">About</p>
          {siteMeta.about.map((paragraph) => (
            <p>{paragraph}</p>
          ))}

          <div class="about-page__details">
            <p>
              <span>Location</span>
              <strong>{siteMeta.location}</strong>
            </p>
            <p>
              <span>Email</span>
              <a>{siteMeta.email}</a>
            </p>
            <p>
              <span>Instagram</span>
              <a href={siteMeta.instagramUrl} rel="noreferrer" target="_blank">
                liamadio
              </a>
            </p>
          </div>
        </div>
      </section>
    </main>
  </div>
</BaseLayout>
