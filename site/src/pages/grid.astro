---
import MobileHeader from "../components/MobileHeader.astro";
import PhotoGrid from "../components/PhotoGrid.astro";
import Sidebar from "../components/Sidebar.astro";
import { photos } from "../data/photos";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Grid | liamamad.io" canonicalPath="/grid">
  <MobileHeader currentPath="/grid" />
  <div class="desktop-frame">
    <Sidebar />

    <main class="page-shell page-shell--grid">
      <section class="grid-page">
        <PhotoGrid photos={photos} />
      </section>
    </main>
  </div>
</BaseLayout>

<script is:inline>
  document.addEventListener("keydown", (event) => {
    if (event.key !== "Escape") {
      return;
    }

    const referrer = document.referrer;

    if (referrer && referrer.startsWith(window.location.origin) && !referrer.includes("/grid")) {
      window.location.assign(referrer);
      return;
    }

    window.location.assign("/");
  });
</script>
